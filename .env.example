# Example environment for local development & testing.
# Copy the relevant block into a real (gitignored) file and fill in values.
# Never commit real credentials — use throwaway, bucket-scoped keys.

# ----------------------------------------------------------------------------
# e2e tests  →  copy these into `.env.test`
# ----------------------------------------------------------------------------
# The Rust e2e suite (`cargo test --test e2e` / `just e2e`) skips entirely
# unless this file exists. Point it at a disposable, bucket-scoped credential.
OCC_TEST_ENDPOINT=https://s3.example.com
OCC_TEST_REGION=us-east-1
OCC_TEST_BUCKET=my-test-bucket
OCC_TEST_ACCESS_KEY_ID=
OCC_TEST_SECRET_ACCESS_KEY=
OCC_TEST_PATH_STYLE=true
# A demo age key pair used to encrypt/decrypt fixtures in the suite.
# Generate with `age-keygen`.
OCC_TEST_AGE_PUBLIC_KEY=age1...
OCC_TEST_AGE_SECRET_KEY=AGE-SECRET-KEY-1...

# ----------------------------------------------------------------------------
# dev auto-seed  →  copy these into `.env.development.local`
# ----------------------------------------------------------------------------
# When present, `pnpm tauri dev` auto-creates a "Demo (dev)" connection so you
# don't re-enter test data. Dev-only (import.meta.env.DEV); never in production.
VITE_DEV_ENDPOINT=https://s3.example.com
VITE_DEV_REGION=us-east-1
VITE_DEV_BUCKET=my-test-bucket
VITE_DEV_ACCESS_KEY_ID=
VITE_DEV_SECRET=
VITE_DEV_PATH_STYLE=true
VITE_DEV_AGE_KEY=AGE-SECRET-KEY-1...
